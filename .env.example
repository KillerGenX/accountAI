# ==============================================================================
# PROJECT BRAIN - Local Environment Configuration Template
# Rename this file to `.env` and fill in the values from your Supabase Dashboard
# ==============================================================================

# Supabase Hosted Services (Cloud Web Dashboard)
# ------------------------------------------------------------------------------
# Retrieve these from: Project Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# PostgreSQL Direct Connection String (Supabase database)
# ------------------------------------------------------------------------------
# Retrieve from: Project Settings -> Database -> Connection string -> URI
# NOTE: Replace [YOUR-PASSWORD] with your actual Supabase DB password.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# AI / Large Language Models Gateway (LiteLLM)
# ------------------------------------------------------------------------------
# Keys for the LLM providers you plan to use
GEMINI_API_KEY=AIzaSy...
OPENAI_API_KEY=sk-...

# Local Dev Infrastructure (Docker Compose Services)
# ------------------------------------------------------------------------------
# These match the default ports exposed by docker-compose.yml
REDIS_URL=redis://localhost:6379/0
NATS_URL=nats://localhost:4222
TEMPORAL_HOST=localhost:7233
ENVIRONMENT=development
